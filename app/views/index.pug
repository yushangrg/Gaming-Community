extends layout

block content
  - const safePosts = typeof posts !== 'undefined' && posts ? posts : []
  - const activeCategory = typeof category !== 'undefined' ? category : ''
  - const activeTag = typeof tag !== 'undefined' ? tag : ''
  - const activeSearch = typeof search !== 'undefined' ? search : ''
  - const activeType = typeof postType !== 'undefined' ? postType : (typeof selectedType !== 'undefined' ? selectedType : '')
  - const activeDifficulty = typeof difficulty !== 'undefined' ? difficulty : (typeof selectedDifficulty !== 'undefined' ? selectedDifficulty : '')
  - const viewer = (typeof currentUser !== 'undefined' && currentUser) ? currentUser : (typeof user !== 'undefined' ? user : null)
  - const titleText = typeof pageTitle !== 'undefined' && pageTitle ? pageTitle : 'Game Posts'
  - const categories = ['Action', 'Adventure', 'RPG', 'Shooter', 'Strategy', 'Racing', 'Sports', 'Indie', 'FPS', 'Tips', 'Mobile']
  - const tagsList = ['RPG', 'Guide', 'Beginner', 'FPS', 'Tips', 'Mobile', 'Indie']
  - const typeOptions = typeof postTypes !== 'undefined' && postTypes ? postTypes : ['Guide', 'Tip', 'Trick', 'Review', 'News', 'Question', 'Discussion', 'Video']
  - const difficultyOptions = typeof difficulties !== 'undefined' && difficulties ? difficulties : ['Beginner', 'Intermediate', 'Advanced', 'Pro']
  -
    const buildPostUrl = (updates = {}) => {
      const next = {
        category: activeCategory,
        tag: activeTag,
        type: activeType,
        difficulty: activeDifficulty,
        search: activeSearch,
        ...updates
      };

      const params = new URLSearchParams();

      Object.keys(next).forEach(key => {
        if (next[key]) {
          params.set(key, next[key]);
        }
      });

      const query = params.toString();
      return query ? `/posts?${query}` : '/posts';
    };

  .posts-dashboard-page
    section.posts-hero-panel
      .hero-art-left
      .hero-art-right

      .posts-hero-content
        h1 Share. Discuss. 
          span Dominate.
        p Join the ultimate gaming community. Share guides, tips, tricks, reviews, news, questions, videos, and epic gaming moments.

        form(action="/posts" method="GET" class="hero-search-form")
          if activeCategory
            input(type="hidden" name="category" value=activeCategory)
          if activeTag
            input(type="hidden" name="tag" value=activeTag)
          if activeType
            input(type="hidden" name="type" value=activeType)
          if activeDifficulty
            input(type="hidden" name="difficulty" value=activeDifficulty)

          input(type="text" name="search" placeholder="Search games, posts, guides, users..." value=activeSearch)
          button(type="submit") Search

    .posts-filter-row
      a.filter-pill(
        class=!activeCategory && !activeTag && !activeType && !activeDifficulty && !activeSearch ? 'active' : ''
        href="/posts"
      ) All Posts

      each item in typeOptions
        a.filter-pill(
          class=activeType === item ? 'active' : ''
          href=buildPostUrl({ type: item })
        )= item

      .sort-pill Latest ▾

    .posts-dashboard-layout
      aside.posts-left-sidebar
        .dashboard-side-card
          h3 Categories
          .category-list
            a.category-row(
              class=!activeCategory ? 'active' : ''
              href=buildPostUrl({ category: '' })
            )
              span.category-name All
              span.category-count= safePosts.length

            each cat in categories
              a.category-row(
                class=activeCategory === cat ? 'active' : ''
                href=buildPostUrl({ category: cat })
              )
                span.category-name= cat
                span.category-count posts

        .dashboard-side-card
          h3 Post Types
          .category-list
            a.category-row(
              class=!activeType ? 'active' : ''
              href=buildPostUrl({ type: '' })
            )
              span.category-name All Types
              span.category-count type

            each item in typeOptions
              a.category-row(
                class=activeType === item ? 'active' : ''
                href=buildPostUrl({ type: item })
              )
                span.category-name= item
                span.category-count type

        .dashboard-side-card
          h3 Difficulty
          .category-list
            a.category-row(
              class=!activeDifficulty ? 'active' : ''
              href=buildPostUrl({ difficulty: '' })
            )
              span.category-name All Levels
              span.category-count level

            each item in difficultyOptions
              a.category-row(
                class=activeDifficulty === item ? 'active' : ''
                href=buildPostUrl({ difficulty: item })
              )
                span.category-name= item
                span.category-count level

        .dashboard-side-card
          h3 Tags
          .category-list
            each tagName in tagsList
              a.category-row(
                class=activeTag === tagName ? 'active' : ''
                href=buildPostUrl({ tag: tagName })
              )
                span.category-name # #{tagName}
                span.category-count tag

      main.posts-feed
        .feed-header
          h2 🎮 #{titleText}

          form(action="/posts" method="GET" class="feed-search-form")
            if activeCategory
              input(type="hidden" name="category" value=activeCategory)
            if activeTag
              input(type="hidden" name="tag" value=activeTag)
            if activeType
              input(type="hidden" name="type" value=activeType)
            if activeDifficulty
              input(type="hidden" name="difficulty" value=activeDifficulty)

            input(type="text" name="search" placeholder="Search posts..." value=activeSearch)
            button(type="submit") Search

        if safePosts.length === 0
          .empty-feed-card
            h3 No posts found
            p Try another search, category, post type, difficulty, or tag.
            a.read-more-btn(href="/posts") View all posts
        else
          .professional-post-list
            each post in safePosts
              - const postDate = post.created_at ? new Date(post.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) : 'Recently'
              - const excerpt = post.content ? (post.content.length > 150 ? post.content.slice(0, 150) + '...' : post.content) : 'No description yet.'
              - const ratingValue = post.rating ? parseFloat(post.rating).toFixed(1) : '0.0'
              - const postTypeValue = post.post_type || (post.video ? 'Video' : 'Guide')
              - const difficultyValue = post.difficulty || 'Beginner'
              - const readTime = Number(post.read_time || 1)
              - const saveCount = Number(post.save_count || 0)
              - const commentsCount = Number(post.comment_count || post.comments_count || post.total_comments || 0)
              - const helpfulCount = Number(post.helpful_count || 0)
              - const notHelpfulCount = Number(post.not_helpful_count || 0)
              - const userFeedback = post.user_feedback || ''
              - const authorInitial = post.username ? post.username.charAt(0).toUpperCase() : 'U'

              article.professional-post-card
                a.post-thumb-link(href=`/posts/${post.id}`)
                  img(
                    src=post.image || "https://placehold.co/640x420/0f172a/f8fafc?text=Gaming"
                    alt=post.title
                  )

                .professional-post-content
                  .card-top-line
                    span.category-badge= post.category || 'Gaming'
                    span.post-time= postDate

                  h3
                    a(href=`/posts/${post.id}`)= post.title

                  .tag-chip-row
                    a.tag-chip(href=buildPostUrl({ type: postTypeValue })) 🧩 #{postTypeValue}
                    a.tag-chip(href=buildPostUrl({ difficulty: difficultyValue })) 🎯 #{difficultyValue}
                    span.tag-chip ⏱ #{readTime} min read

                  p.post-excerpt= excerpt

                  .post-meta-row
                    a.author-mini(href=`/users/${post.user_id}`)
                      .author-mini-avatar= authorInitial
                      span= post.username || 'Unknown'

                    .post-small-stats
                      span 👁 #{post.views || 0}
                      span 💬 #{commentsCount}
                      span 💜 #{post.likes || 0}
                      span 💾 #{saveCount}
                      span 👍 #{helpfulCount}
                      span 👎 #{notHelpfulCount}
                      span ⭐ #{ratingValue}

                  .post-card-actions
                    a.read-more-btn(href=`/posts/${post.id}`) Read Post

                    if viewer
                      form(action=`/posts/${post.id}/save` method="POST")
                        button(type="submit" class=post.is_saved ? 'save-btn is-saved' : 'save-btn')
                          if post.is_saved
                            | 💾 Saved
                          else
                            | 💾 Save

                      form(action=`/posts/${post.id}/feedback` method="POST")
                        input(type="hidden" name="feedback" value="helpful")
                        button(
                          type="submit"
                          class=userFeedback === 'helpful' ? 'feedback-btn helpful active' : 'feedback-btn helpful'
                        ) 👍 Helpful

                      form(action=`/posts/${post.id}/feedback` method="POST")
                        input(type="hidden" name="feedback" value="not_helpful")
                        button(
                          type="submit"
                          class=userFeedback === 'not_helpful' ? 'feedback-btn not-helpful active' : 'feedback-btn not-helpful'
                        ) 👎 Not Helpful
                    else
                      a.save-btn(href="/login") 💾 Save
                      a.feedback-btn.helpful(href="/login") 👍 Helpful
                      a.feedback-btn.not-helpful(href="/login") 👎 Not Helpful

      aside.posts-right-sidebar
        .dashboard-side-card
          h3 Quick Stats
          .quick-stat-list
            .quick-stat-row
              span Showing Posts
              strong= safePosts.length

            .quick-stat-row
              span Active Category
              strong= activeCategory || 'All'

            .quick-stat-row
              span Active Type
              strong= activeType || 'All'

            .quick-stat-row
              span Difficulty
              strong= activeDifficulty || 'All'

            .quick-stat-row
              span Active Tag
              strong= activeTag || 'None'

        .dashboard-side-card
          h3 Better Post System
          p.side-muted Filter posts by type and difficulty to find guides, tips, tricks, reviews, questions, discussions, and pro-level strategies faster.

          .quick-stat-list
            .quick-stat-row
              span Types
              strong= typeOptions.length
            .quick-stat-row
              span Difficulty Levels
              strong= difficultyOptions.length

        .dashboard-side-card
          h3 Feedback System
          p.side-muted Posts can now receive helpful and not helpful feedback, so the best guides are easier to find.

          .quick-stat-list
            .quick-stat-row
              span Helpful votes
              strong 👍
            .quick-stat-row
              span Not helpful votes
              strong 👎

        .dashboard-side-card
          h3 Community
          p.side-muted Discover posts, reviews, tips, builds, guides, videos, and gaming discussions from the community.

          if viewer
            a.side-action-btn(href="/posts/create") Create Post
          else
            a.side-action-btn(href="/login") Login to Create