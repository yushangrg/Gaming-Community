extends layout

block content
  .profile-page
    .profile-card
      .profile-card-head
        div
          h2 ✍️ Create New Post
          p.profile-muted Share a gaming guide, tip, trick, review, question, or discussion.

      form.profile-edit-form(action="/posts/create", method="POST", enctype="multipart/form-data")
        .profile-form-grid
          .form-group.full
            label(for="title") Title
            input(
              type="text"
              id="title"
              name="title"
              placeholder="Example: Best GTA V money tricks"
              required
            )

          .form-group
            label(for="category") Game / Category
            input(
              type="text"
              id="category"
              name="category"
              placeholder="Example: GTA V, Valorant, Minecraft"
              required
            )

          .form-group
            label(for="post_type") Post Type
            select(id="post_type", name="post_type", required)
              option(value="Guide") Guide
              option(value="Tip") Tip
              option(value="Trick") Trick
              option(value="Review") Review
              option(value="News") News
              option(value="Question") Question
              option(value="Discussion") Discussion
              option(value="Video") Video

          .form-group
            label(for="difficulty") Difficulty
            select(id="difficulty", name="difficulty", required)
              option(value="Beginner") Beginner
              option(value="Intermediate") Intermediate
              option(value="Advanced") Advanced
              option(value="Pro") Pro

          .form-group
            label(for="image") Upload Image
            input(
              type="file"
              id="image"
              name="image"
              accept="image/jpeg,image/png,image/webp,image/gif"
            )
            small Max size: 5MB.

          .form-group.full
            label(for="image_url") Or Image URL
            input(
              type="url"
              id="image_url"
              name="image_url"
              placeholder="https://example.com/image.jpg"
            )
            small If you upload an image and also add a URL, the uploaded image will be used.

          .form-group.full
            label(for="video") YouTube Video URL
            input(
              type="url"
              id="video"
              name="video"
              placeholder="https://www.youtube.com/watch?v=VIDEO_ID"
            )

          .form-group.full
            label(for="content") Content
            textarea(
              id="content"
              name="content"
              rows="8"
              placeholder="Write your guide, tip, trick, review, or question..."
              required
            )

        .profile-form-actions
          button.profile-action-btn(type="submit") 🚀 Publish Post