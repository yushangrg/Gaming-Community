extends layout

block content
  .profile-page
    .profile-card
      .profile-card-head
        div
          h2 ✍️ Create New Post
          p.profile-muted Share a gaming tip, guide, review, trick, or tutorial with the community.

      form.profile-edit-form(action="/posts/create", method="POST", enctype="multipart/form-data")
        .profile-form-grid
          .form-group.full
            label(for="title") Title
            input(
              type="text"
              id="title"
              name="title"
              placeholder="Example: Best Valorant aim tips for beginners"
              required
            )

          .form-group
            label(for="category") Category
            select(id="category", name="category", required)
              option(value="FPS") FPS
              option(value="RPG") RPG
              option(value="Tips") Tips
              option(value="Guide") Guide
              option(value="Review") Review
              option(value="Mobile") Mobile
              option(value="Indie") Indie
              option(value="Other") Other

          .form-group
            label(for="image") Upload Image
            input(
              type="file"
              id="image"
              name="image"
              accept="image/jpeg,image/png,image/webp,image/gif"
            )
            small Upload a screenshot, cover image, or gaming image. Max size: 5MB.

          .form-group.full
            label(for="image_url") Or Image URL
            input(
              type="url"
              id="image_url"
              name="image_url"
              placeholder="https://example.com/image.jpg"
            )
            small If you upload an image and also add a URL, the uploaded image will be used.

          .form-group.full
            label(for="video") YouTube Video URL
            input(
              type="url"
              id="video"
              name="video"
              placeholder="https://www.youtube.com/watch?v=VIDEO_ID"
            )
            small You can paste a normal YouTube link. The app will convert it to an embed link automatically.

          .form-group.full
            label(for="content") Content
            textarea(
              id="content"
              name="content"
              rows="8"
              placeholder="Write your gaming post, tip, walkthrough, or strategy..."
              required
            )

        .profile-form-actions
          button.profile-action-btn(type="submit") 🚀 Publish Post