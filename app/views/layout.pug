doctype html
html
  head
    title Gaming Community
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet", href="/style.css")

  body
    .navbar
      div GAMING-COMMUNITY
      div
        a(href="/") Home
        a(href="/posts") Posts
        a(href="/users") Users
        a(href="/profile") Profile

        if !user
          a(href="/login") Login
        else
          a(href="/posts/create") Create Post
          a(href="/logout") Logout

    block content

    footer.footer
      .footer-container
        .footer-left
          p 2025 Gaming Community
          p.small Independent platform. All game content and trademarks belong to their respective owners.

        .footer-links
          a(href="/about") About
          a(href="/privacy-policy") Privacy Policy
          a(href="/terms-of-service") Terms of Service
          a(href="/support") Support

        .footer-right
          span EN
          span.social Gaming