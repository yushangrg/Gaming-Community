extends layout

block content
  .main
    if !user
      .center-card
        h3 Access Your Profile
        p Please login or create an account

        a(href="/login")
          button Login

        a(href="/register")
          button Create Account

        p(style="margin-top:10px") Continue browsing as guest
    else
      .profile-header
        h2= user.username
        p 📄 #{posts.length} posts

      .clips
        each post in posts
          a(href=`/posts/${post.id}`)
            .clip Clip