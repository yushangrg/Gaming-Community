extends layout

block content
  .profile-page
    .profile-card
      .profile-card-head
        div
          h2 ✏️ Edit Post
          p.profile-muted Update your post details.

        a.profile-secondary-btn(href=`/posts/${post.id}`) Cancel

      form.profile-edit-form(action=`/posts/${post.id}/edit`, method="POST", enctype="multipart/form-data")
        .profile-form-grid
          .form-group.full
            label(for="title") Title
            input(
              type="text"
              id="title"
              name="title"
              value=post.title
              required
            )

          .form-group
            label(for="category") Game / Category
            input(
              type="text"
              id="category"
              name="category"
              value=post.category
              required
            )

          .form-group
            label(for="post_type") Post Type
            select(id="post_type", name="post_type", required)
              option(value="Guide", selected=post.post_type === "Guide") Guide
              option(value="Tip", selected=post.post_type === "Tip") Tip
              option(value="Trick", selected=post.post_type === "Trick") Trick
              option(value="Review", selected=post.post_type === "Review") Review
              option(value="News", selected=post.post_type === "News") News
              option(value="Question", selected=post.post_type === "Question") Question
              option(value="Discussion", selected=post.post_type === "Discussion") Discussion
              option(value="Video", selected=post.post_type === "Video") Video

          .form-group
            label(for="difficulty") Difficulty
            select(id="difficulty", name="difficulty", required)
              option(value="Beginner", selected=post.difficulty === "Beginner") Beginner
              option(value="Intermediate", selected=post.difficulty === "Intermediate") Intermediate
              option(value="Advanced", selected=post.difficulty === "Advanced") Advanced
              option(value="Pro", selected=post.difficulty === "Pro") Pro

          .form-group
            label(for="image") Upload New Image
            input(
              type="file"
              id="image"
              name="image"
              accept="image/jpeg,image/png,image/webp,image/gif"
            )
            small Leave empty to keep the current image.

          if post.image
            .form-group.full
              label Current Image
              .post-image-frame
                img(src=post.image, alt=post.title)

          .form-group.full
            label(for="image_url") Or Replace With Image URL
            input(
              type="url"
              id="image_url"
              name="image_url"
              value=post.image && !post.image.startsWith('/uploads/') ? post.image : ''
              placeholder="https://example.com/image.jpg"
            )

          .form-group.full
            label(for="video") YouTube Video URL
            input(
              type="url"
              id="video"
              name="video"
              value=post.video || ''
              placeholder="https://www.youtube.com/watch?v=VIDEO_ID"
            )

          .form-group.full
            label(for="content") Content
            textarea(
              id="content"
              name="content"
              rows="8"
              required
            )= post.content

        .profile-form-actions
          button.profile-action-btn(type="submit") 💾 Save Changes