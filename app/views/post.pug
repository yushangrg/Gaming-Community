extends layout

mixin renderComment(comment, post, currentUser, level)
  - const commentInitial = comment.username ? comment.username.charAt(0).toUpperCase() : 'U'
  - const commentDate = comment.created_at ? new Date(comment.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) : 'Now'

  .comment-thread-item(class=level > 0 ? 'is-reply' : '', id=`comment-${comment.id}`)
    .comment-avatar= commentInitial

    .comment-body
      .comment-top
        .comment-user
          strong= comment.username || 'Unknown'
          span.comment-date= commentDate

      p.comment-text= comment.content

      .comment-actions
        if currentUser
          form(action=`/posts/comments/${comment.id}/react` method="POST")
            input(type="hidden" name="reaction" value="like")
            button(type="submit" class="comment-action-btn") 👍 #{comment.reactionCounts && comment.reactionCounts.like ? comment.reactionCounts.like : 0}

          form(action=`/posts/comments/${comment.id}/react` method="POST")
            input(type="hidden" name="reaction" value="helpful")
            button(type="submit" class="comment-action-btn") 💡 #{comment.reactionCounts && comment.reactionCounts.helpful ? comment.reactionCounts.helpful : 0}

          form(action=`/posts/comments/${comment.id}/react` method="POST")
            input(type="hidden" name="reaction" value="funny")
            button(type="submit" class="comment-action-btn") 😂 #{comment.reactionCounts && comment.reactionCounts.funny ? comment.reactionCounts.funny : 0}

          if !comment.hasReported
            form(action=`/posts/comments/${comment.id}/report` method="POST")
              button(type="submit" class="comment-action-btn warning") 🚩 Report
          else
            span.comment-status Reported

          form(action=`/posts/${post.id}/comment/${comment.id}/reply` method="POST" class="comment-reply-form")
            textarea(name="content" rows="2" placeholder="Write a reply..." required)
            button(type="submit" class="comment-action-btn accent") Reply

          if comment.isOwner
            form(action=`/posts/comments/${comment.id}/delete` method="POST" onsubmit="return confirm('Delete this comment?');")
              button(type="submit" class="comment-action-btn danger") 🗑 Delete
        else
          span.comment-status Login to react or reply

      if comment.replies && comment.replies.length
        .comment-replies
          each reply in comment.replies
            +renderComment(reply, post, currentUser, level + 1)

block content
  - const safeComments = typeof comments !== 'undefined' && comments ? comments : []
  - const safeTags = typeof tags !== 'undefined' && tags ? tags : []
  - const currentUser = typeof user !== 'undefined' ? user : null
  - const countComments = (items = []) => items.reduce((sum, item) => sum + 1 + countComments(item.replies || []), 0)
  - const totalComments = countComments(safeComments)
  - const published = post.created_at ? new Date(post.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) : 'Recently'
  - const authorInitial = post.username ? post.username.charAt(0).toUpperCase() : 'U'
  - const ratingValue = post.rating ? parseFloat(post.rating).toFixed(1) : '0.0'

  .post-detail-page
    .post-page-container
      .post-breadcrumbs
        a(href="/") Home
        span ›
        a(href="/posts") Posts
        span ›
        span= post.title

      .post-layout
        main.post-main
          article.ui-card.post-hero-card
            .post-top-row
              .post-left-meta
                span.category-badge= post.category || 'Gaming'
              .post-right-meta
                span Posted #{published}

            h1.post-title= post.title

            .post-author-row
              .author-chip
                .author-avatar= authorInitial
                .author-copy
                  strong= post.username || 'Unknown'
                  span Community member

              if currentUser && currentUser.id === post.user_id
                .owner-actions
                  a(href=`/posts/${post.id}/edit`)
                    button(type="button" class="ghost-btn") ✏️ Edit
                  form(action=`/posts/${post.id}/delete` method="POST" onsubmit="return confirm('Delete this post?');")
                    button(type="submit" class="ghost-btn danger") 🗑 Delete

            .post-like-row
              a(href=`/posts/${post.id}/like`)
                button(type="button" class="like-btn") 💜 Like #{post.likes || 0}

            .post-image-frame
              img(src=post.image || "https://placehold.co/1200x700/0f172a/f8fafc?text=Gaming" alt=post.title)

            if post.video
              .post-video-frame
                iframe(
                  width="100%"
                  height="420"
                  src=post.video
                  title="Game video"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                )

            .post-content
              p.post-body-copy= post.content

            if safeTags.length
              .tag-chip-row
                each tag in safeTags
                  a.tag-chip(href=`/posts?tag=${tag.name}`)= `#${tag.name}`

            .post-footer-stats
              .stat-pill 👁 #{post.views || 0} Views
              .stat-pill 💬 #{totalComments} Comments
              .stat-pill ⭐ #{ratingValue} Rating

        aside.post-sidebar
          .ui-card.side-card
            h3.side-title ✨ Post Info
            .info-list
              .info-row
                span.label Category
                span.value= post.category || 'Gaming'
              .info-row
                span.label Published
                span.value= published
              .info-row
                span.label Likes
                span.value= post.likes || 0
              .info-row
                span.label Rating
                span.value #{ratingValue} / 5

          if currentUser
            .ui-card.side-card
              h3.side-title ⭐ Rate This Post
              form(action=`/posts/${post.id}/rate` method="POST" class="side-rate-form")
                select(name="rating")
                  option(value="1") 1 Star
                  option(value="2") 2 Stars
                  option(value="3") 3 Stars
                  option(value="4") 4 Stars
                  option(value="5") 5 Stars
                button(type="submit" class="primary-btn") Submit Rating
          else
            .ui-card.side-card
              h3.side-title ⭐ Rating
              p.login-hint
                a(href="/login") Login
                |  to submit a rating.

          if safeTags.length
            .ui-card.side-card
              h3.side-title 🏷 Tags
              .tag-chip-row.sidebar-tags
                each tag in safeTags
                  a.tag-chip(href=`/posts?tag=${tag.name}`)= tag.name

          .ui-card.comments-card.sidebar-comments
            .section-head
              h3 💬 Comments
              span.comment-count= totalComments

            if currentUser
              form(action=`/posts/${post.id}/comment` method="POST" class="comment-form")
                textarea(name="content" rows="3" placeholder="Add a comment..." required)
                .comment-form-actions
                  button(type="submit" class="primary-btn") Post Comment
            else
              p.login-hint
                a(href="/login") Login
                |  to comment, react, or reply.

            if safeComments.length === 0
              p.empty-comments No comments yet.
            else
              .comment-list
                each comment in safeComments
                  +renderComment(comment, post, currentUser, 0)