extends layout

block content
  .main
    h2 #{post.title}

    .container
      .main-content
        img(src=post.image || "https://placehold.co/800x400/1a1a2e/ffffff?text=Gaming" style="width:100%; height:400px; object-fit:contain; background:#111;")

        if post.video
          div(style="margin:20px 0;")
            iframe(
              width="100%"
              height="400"
              src=post.video
              title="Game video"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              style="border-radius:12px;"
            )

        h3= post.title
        p By #{post.username}

        .actions
          a(href=`/posts/${post.id}/like`)
            button Like (#{post.likes})

        p Rating: #{post.rating ? parseFloat(post.rating).toFixed(1) : '0'} / 5

        if user
          h4 Rate this post
          form(action=`/posts/${post.id}/rate` method="POST" style="margin-bottom:16px;")
            select(name="rating" style="padding:8px; margin-right:8px;")
              option(value="1") 1 Star
              option(value="2") 2 Stars
              option(value="3") 3 Stars
              option(value="4") 4 Stars
              option(value="5") 5 Stars
            button(type="submit" style="padding:8px 16px;") Submit Rating
        else
          p
            a(href="/login") Login
            |  to rate this post

        h4 Tags
        each tag in tags
          a(href=`/posts?tag=${tag.name}` style="margin-right:10px") #{tag.name}

      .sidebar
        h3 Comments

        if comments.length === 0
          p No comments yet.

        each comment in comments
          .card
            p #{comment.content}
            small by #{comment.username}

        if user
          h4 Leave a Comment
          form(action=`/posts/${post.id}/comment` method="POST")
            textarea(name="content" rows="3" placeholder="Write your comment..." style="width:100%; padding:8px; margin-bottom:8px;")
            br
            button(type="submit" style="padding:8px 16px;") Post Comment
        else
          p
            a(href="/login") Login
            |  to leave a comment